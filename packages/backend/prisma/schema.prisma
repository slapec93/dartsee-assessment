generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id          Int          @id
  type        String?
  gamePlayers GamePlayer[]
  throws      Throw[]

  @@map("games")
}

model Player {
  id          String       @id
  name        String?
  gamePlayers GamePlayer[]
  throws      Throw[]

  @@map("players")
}

model GamePlayer {
  id       String  @id
  gameId   Int     @map("game_id")
  playerId String? @map("player_id")
  game     Game    @relation(fields: [gameId], references: [id])
  player   Player? @relation(fields: [playerId], references: [id])

  @@map("game_players")
}

model Throw {
  id       Int     @id
  gameId   Int?    @map("game_id")
  playerId String? @map("player_id")
  score    Int?
  modifier Int?
  x        Int?
  y        Int?
  game     Game?   @relation(fields: [gameId], references: [id])
  player   Player? @relation(fields: [playerId], references: [id])

  @@map("throws")
}

{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "prisma generate && bash scripts/test_setup.sh",
    "test:setup": "bash scripts/test_setup.sh",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@dartsee-assessment/shared": "workspace:*",
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
